{
  "manifest_version": 3,
  "name": "YouTube Video Tracker",
  "version": "2.0",
  "description": "Authenticated Tracking Agent syncing with Next.js Dashboard",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
