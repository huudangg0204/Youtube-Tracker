# ── YouTube Tracker – Environment Variables ───────────────────────
# Copy file này thành .env rồi điền giá trị thực:
#   cp .env.example .env

# Server
PORT=5000

# ─── InfluxDB v3 Core ─────────────────────────────────────────────
# Nếu chạy Docker: host sẽ được override thành http://influxdb:8181
# Nếu chạy local:  dùng http://localhost:8181
INFLUXDB_HOST=http://localhost:8181
INFLUXDB_TOKEN=<your_influxdb_admin_token>
INFLUXDB_DATABASE=youtube_tracking_data

# ─── Supabase Auth ────────────────────────────────────────────────
# Lấy từ: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your_supabase_anon_key>

# ─── Redis Cache ──────────────────────────────────────────────────
# Nếu chạy Docker: host sẽ được override thành redis://redis:6379
REDIS_URL=redis://localhost:6379

# ─── YouTube Data API v3 ─────────────────────────────────────────
YOUTUBE_API_KEY=<your_youtube_api_key>

# ─── Last.fm API ────────────────────────────────────────────────────
# Lấy từ: https://www.last.fm/api/account/create (miễn phí, không cần OAuth)
LASTFM_API_KEY=<your_lastfm_api_key>

# ─── Google Gemini API ────────────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your_gemini_api_key>
